{
  "productName": "Flux Explorer",
  "version": "0.1.0",
  "identifier": "com.flux.explorer",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx serve src -l 1420 -L"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flux Explorer",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "opener": {}
  }
}
